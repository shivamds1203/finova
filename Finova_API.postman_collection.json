                                "value": "Bearer {{token}}"
                            }
                        ]
                    }
                },
                {
                    "name": "Transfer Funds",
                    "request": {
                        "method": "POST",
                        "url": "{{baseUrl}}/api/wallet/transfer",
                        "header": [
