                {
                    "name": "Get Stock Details",
                    "request": {
                        "method": "GET",
                        "url": "{{baseUrl}}/api/investments/AAPL",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            }
                        ],
                        "description": "Get details for a specific symbol (e.g. AAPL, NVDA, BTC)"
