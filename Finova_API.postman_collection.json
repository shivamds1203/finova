                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"fileName\": \"portfolio_q1_2026.pdf\",\n  \"fileType\": \"application/pdf\",\n  \"fileSize\": 245760\n}"
                        }
                    }
                },
                {
                    "name": "Parse Document (AI)",
                    "request": {
                        "method": "POST",
                        "url": "{{baseUrl}}/api/documents/d1/parse",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            }
                        ],
                        "description": "Triggers AI extraction of investment data from a document"
                    }
                },
                {
                    "name": "Delete Document",
                    "request": {
                        "method": "DELETE",
                        "url": "{{baseUrl}}/api/documents/d1",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            }
                        ]
                    }
                }
            ]
        },
        {
            "name": "📋 Reports",
            "item": [
                {
                    "name": "Get Transactions",
                    "request": {
                        "method": "GET",
                        "url": {
                            "raw": "{{baseUrl}}/api/reports/transactions?startDate=2026-02-01&endDate=2026-02-28",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "reports",
                                "transactions"
                            ],
                            "query": [
                                {
                                    "key": "startDate",
                                    "value": "2026-02-01"
                                },
                                {
                                    "key": "endDate",
                                    "value": "2026-02-28"
                                },
                                {
                                    "key": "category",
                                    "value": "",
                                    "disabled": true
                                }
                            ]
                        },
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            }
                        ]
                    }
                },
                {
                    "name": "Get Monthly Summary",
                    "request": {
                        "method": "GET",
                        "url": {
                            "raw": "{{baseUrl}}/api/reports/summary?month=02&year=2026",
                            "host": [
