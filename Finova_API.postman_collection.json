                            ],
                            "path": [
                                "api",
                                "reports",
                                "summary"
                            ],
                            "query": [
                                {
                                    "key": "month",
                                    "value": "02"
                                },
                                {
                                    "key": "year",
                                    "value": "2026"
                                }
                            ]
                        },
                        "header": [
