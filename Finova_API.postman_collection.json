                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"cardNumber\": \"4111111111111111\",\n  \"expiry\": \"12/29\",\n  \"cvv\": \"123\",\n  \"name\": \"Alex Sterling\"\n}"
                        }
                    }
                }
            ]
        },
        {
            "name": "🏦 Credit",
            "item": [
                {
                    "name": "Get Credit Score",
                    "request": {
                        "method": "GET",
