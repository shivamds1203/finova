{
    "info": {
        "name": "Finova API",
        "description": "Complete Postman collection for the Finova Finance App API. Base URL: http://localhost:5000",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "variable": [
        {
            "key": "baseUrl",
            "value": "http://localhost:5000",
            "type": "string"
        },
        {
            "key": "token",
            "value": "",
            "type": "string"
        }
    ],
    "item": [
        {
            "name": "🔑 Auth",
            "item": [
                {
                    "name": "Health Check",
                    "request": {
                        "method": "GET",
                        "url": "{{baseUrl}}/",
                        "description": "Check if the API server is running"
                    }
                },
                {
                    "name": "Login",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "const res = pm.response.json();",
                                    "if (res.token) pm.collectionVariables.set('token', res.token);",
                                    "pm.test('Login successful', () => pm.response.to.have.status(200));"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "url": "{{baseUrl}}/api/auth/login",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"email\": \"alex@finova.io\",\n  \"password\": \"password123\"\n}"
                        },
                        "description": "Login with email and password. Token is auto-saved."
                    }
                },
                {
                    "name": "Register",
                    "request": {
                        "method": "POST",
                        "url": "{{baseUrl}}/api/auth/register",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"name\": \"Shivam Suryawanshi\",\n  \"email\": \"shivam@finova.io\",\n  \"password\": \"securePass456\"\n}"
                        }
                    }
                },
                {
                    "name": "Get Current User",
                    "request": {
                        "method": "GET",
                        "url": "{{baseUrl}}/api/auth/me",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            }
                        ]
                    }
                },
                {
                    "name": "Forgot Password",
                    "request": {
                        "method": "POST",
                        "url": "{{baseUrl}}/api/auth/forgot-password",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"email\": \"alex@finova.io\"\n}"
                        }
                    }
                },
                {
                    "name": "Logout",
                    "request": {
                        "method": "POST",
                        "url": "{{baseUrl}}/api/auth/logout",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            }
                        ]
                    }
                }
            ]
        },
        {
            "name": "📊 Dashboard",
            "item": [
                {
                    "name": "Get Overview",
                    "request": {
                        "method": "GET",
                        "url": "{{baseUrl}}/api/dashboard/overview",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            }
                        ],
                        "description": "Get balance, income, expenses, savings summary"
                    }
                },
                {
                    "name": "Get Financial Health Score",
                    "request": {
                        "method": "GET",
                        "url": "{{baseUrl}}/api/dashboard/financial-health",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            }
                        ]
                    }
                }
            ]
        },
        {
            "name": "💸 Expenses",
            "item": [
                {
                    "name": "Get All Expenses",
                    "request": {
                        "method": "GET",
                        "url": {
                            "raw": "{{baseUrl}}/api/expenses?month=02&year=2026",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "expenses"
                            ],
                            "query": [
                                {
                                    "key": "month",
                                    "value": "02"
                                },
                                {
                                    "key": "year",
                                    "value": "2026"
                                },
                                {
                                    "key": "category",
                                    "value": "",
                                    "disabled": true
                                }
                            ]
                        },
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            }
                        ]
                    }
                },
                {
                    "name": "Add Expense",
                    "request": {
                        "method": "POST",
                        "url": "{{baseUrl}}/api/expenses",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            },
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"description\": \"Gym Membership\",\n  \"category\": \"Health\",\n  \"amount\": 49.99,\n  \"date\": \"2026-02-28\",\n  \"recurring\": true\n}"
                        }
                    }
                },
                {
                    "name": "Update Expense",
                    "request": {
                        "method": "PUT",
                        "url": "{{baseUrl}}/api/expenses/1",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            },
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"description\": \"Starbucks Coffee (Updated)\",\n  \"amount\": 7.50\n}"
                        }
                    }
                },
                {
                    "name": "Delete Expense",
                    "request": {
                        "method": "DELETE",
                        "url": "{{baseUrl}}/api/expenses/1",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            }
                        ]
                    }
                },
                {
                    "name": "Get Expense Categories",
                    "request": {
                        "method": "GET",
                        "url": "{{baseUrl}}/api/expenses/categories",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            }
                        ]
                    }
                }
            ]
        },
        {
            "name": "📈 Investments",
            "item": [
                {
                    "name": "Get Portfolio",
                    "request": {
                        "method": "GET",
                        "url": "{{baseUrl}}/api/investments",
                        "header": [
